    {"type":"text","id":"s3h","x":590,"y":378,"width":450,"height":24,"text":"三、记忆管理（三层压缩策略）","fontSize":18,"fontFamily":5,"textAlign":"left","strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","roughness":1,"opacity":100},

    {"type":"rectangle","id":"mc","x":590,"y":408,"width":540,"height":480,"strokeColor":"#868e96","backgroundColor":"#f8f9fa","fillStyle":"solid","roughness":1,"opacity":30,"strokeStyle":"dashed"},

    {"type":"rectangle","id":"t1","x":608,"y":428,"width":504,"height":120,"strokeColor":"#0c8599","backgroundColor":"#c5f6fa","fillStyle":"solid","roughness":1,"opacity":100},
    {"type":"text","id":"t1-title","x":613,"y":435,"width":494,"height":22,"text":"第一层：Active Context（活跃上下文）","fontSize":14,"fontFamily":5,"textAlign":"left","strokeColor":"#0b7285","backgroundColor":"transparent","fillStyle":"solid","roughness":1,"opacity":100},
    {"type":"text","id":"t1-body","x":613,"y":459,"width":494,"height":80,"text":"• 保留最近 KEEP_RECENT=3 条完整工具输出\n• 完整的助手消息和用户对话轮次\n• 当前正在使用的 tool_call 结果（完整内容）","fontSize":13,"fontFamily":5,"textAlign":"left","strokeColor":"#0b7285","backgroundColor":"transparent","fillStyle":"solid","roughness":1,"opacity":100},

    {"type":"arrow","id":"at12","x":860,"y":548,"width":0,"height":20,"points":[[0,0],[0,20]],"strokeColor":"#868e96","backgroundColor":"transparent","fillStyle":"solid","roughness":1,"opacity":100,"startArrowhead":null,"endArrowhead":"arrow"},

    {"type":"rectangle","id":"t2","x":608,"y":568,"width":504,"height":120,"strokeColor":"#f08c00","backgroundColor":"#ffe8cc","fillStyle":"solid","roughness":1,"opacity":100},
    {"type":"text","id":"t2-title","x":613,"y":575,"width":494,"height":22,"text":"第二层：Micro Compact（微压缩 · 每轮迭代自动触发）","fontSize":14,"fontFamily":5,"textAlign":"left","strokeColor":"#e67700","backgroundColor":"transparent","fillStyle":"solid","roughness":1,"opacity":100},
    {"type":"text","id":"t2-body","x":613,"y":599,"width":494,"height":80,"text":"• 触发时机：每次 agent_loop 迭代开始时\n• 旧工具输出 → \"[Previous: used <tool_name>]\"\n• 保留调用轨迹，显著减少 token 占用，不丢结构","fontSize":13,"fontFamily":5,"textAlign":"left","strokeColor":"#e67700","backgroundColor":"transparent","fillStyle":"solid","roughness":1,"opacity":100},

    {"type":"arrow","id":"at23","x":860,"y":688,"width":0,"height":20,"points":[[0,0],[0,20]],"strokeColor":"#868e96","backgroundColor":"transparent","fillStyle":"solid","roughness":1,"opacity":100,"startArrowhead":null,"endArrowhead":"arrow"},

    {"type":"rectangle","id":"t3","x":608,"y":708,"width":504,"height":160,"strokeColor":"#c92a2a","backgroundColor":"#ffc9c9","fillStyle":"solid","roughness":1,"opacity":100},
    {"type":"text","id":"t3-title","x":613,"y":715,"width":494,"height":22,"text":"第三层：Auto Compact（自动归档压缩）","fontSize":14,"fontFamily":5,"textAlign":"left","strokeColor":"#c92a2a","backgroundColor":"transparent","fillStyle":"solid","roughness":1,"opacity":100},
    {"type":"text","id":"t3-body","x":613,"y":739,"width":494,"height":120,"text":"• 触发条件：估算 token 数 > 50,000\n• ① 全量保存到 .transcripts/transcript_<timestamp>.jsonl（无损备份）\n• ② 调用 LLM 生成整段对话摘要\n• ③ 用 [摘要消息 + 确认回复] 替换全部上下文\n• 支持理论上无限长度的对话","fontSize":13,"fontFamily":5,"textAlign":"left","strokeColor":"#c92a2a","backgroundColor":"transparent","fillStyle":"solid","roughness":1,"opacity":100}
  ],
